{
  "name": "ngx-tailwind-ui",
  "version": "0.0.0",
  "workspaces": [
    "projects/bottom-sheet-modal",
    "projects/toast",
    "projects/phonenumbers"
  ],
  "description": "Tailwind CSS UI components for Angular",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "serve:ssr:demo": "node dist/demo/server/server.mjs",
    "build:demo": "ng build demo",
    "watch:demo": "ng build demo --watch --configuration development",
    "build": "ng build",
    "build:all": "ng build bottom-sheet-modal && ng build toast && ng build phonenumbers",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "release": "npm version --no-git-tag-version --workspaces=true",
    "release:all": "npm version --no-git-tag-version --workspaces=true",
    "release:bottom-sheet-modal": "npm version --no-git-tag-version -w @ngx-tailwind-ui/bottom-sheet-modal",
    "release:toast": "npm version --no-git-tag-version -w @ngx-tailwind-ui/toast",
    "release:phonenumbers": "npm version --no-git-tag-version -w @ngx-tailwind-ui/phonenumbers",
    "angular:update": "ng update @angular/core@latest @angular/cli@latest"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.6",
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/platform-browser-dynamic": "^22.0.6",
    "@angular/platform-server": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@angular/ssr": "^22.0.6",
    "awesome-phonenumber": "^7.8.0",
    "express": "^4.18.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "autoprefixer": "^10.4.20",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^22.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  }
}
